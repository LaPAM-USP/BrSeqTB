/*
 * brseqtb — Production Config
 * Default: Conda only
 */

nextflow.enable.dsl = 2
profile = 'standard'


/*
 * ============================================================
 * GLOBAL RESOURCE MODEL (Integrated)
 * ============================================================
 */

def totalCpus = Runtime.runtime.availableProcessors()
def usable    = Math.max(2, (totalCpus * 0.65) as int)

executor {
  queueSize = usable
}

/*
 * ============================================================
 * GLOBAL PARAMETERS
 * ============================================================
 */

params {
  run                = null
  add_kaiju_manually = false
  input_table        = "input/input_table.tsv"
  reads_dir          = "reads"
}

/*
 * ============================================================
 * ENVIRONMENT — CONDA (OFFICIAL BACKEND)
 * ============================================================
 */

conda {
  enabled  = true
  useMamba = false
  cacheDir = "$HOME/.nextflow_conda_cache"
}
/*
 * ============================================================
 * PROFILES
 * ============================================================
 */

profiles {

  /*
   * =========================================================
   * STANDARD — Local Auto (65%)
   * =========================================================
   */

  standard {

    process {

      executor      = 'local'
      shell         = ['/bin/bash', '-euo', 'pipefail']
      errorStrategy = 'terminate'
      conda         = "$projectDir/envs/brseqtb.yml"

      // Derivado do usable global
      def heavy = Math.min(4, usable)
      def parallel = Math.max(1, (usable / heavy) as int)

      withName: KAIJU_DB               { cpus = 1; maxForks = 1 }
      withName: OMS_CATALOG            { cpus = 1; maxForks = 1 }
      withName: BWA_REF                { cpus = 1; maxForks = 1 }
      withName: GATK_DICT              { cpus = 1; maxForks = 1 }
      withName: SNPEFF_DB              { cpus = 1; maxForks = 1 }
      withName: MAKE_MANIFEST_VALIDATE { cpus = 1; maxForks = 1 }

      withName: BWA         { cpus = heavy; maxForks = parallel; memory = '4 GB' }
      withName: GATK_GVCF   { cpus = heavy; maxForks = parallel; memory = '8 GB' }
      withName: GATK_VCF    { cpus = heavy; maxForks = parallel; memory = '8 GB' }
      withName: IQTREE      { cpus = heavy; maxForks = 1; memory = '4 GB' }
      withName: COHORT      { cpus = heavy; maxForks = 1; memory = '8 GB' }
      
      withName: SNP_MATRIX   { cpus = 2; maxForks = 1; memory = '4 GB' }
      withName: TRANSMISSION { cpus = 2; maxForks = 1; memory = '2 GB' }

      withName: TRIMMOMATIC { cpus = 2; maxForks = parallel; memory = '2 GB' }

      withName: FASTQC  { cpus = 1; maxForks = parallel; memory = '1 GB' }
      withName: DELLY   { cpus = 1; memory = '2 GB' }
      withName: LOFREQ  { cpus = 1; memory = '2 GB' }
      withName: SNPEFF  { cpus = 1; memory = '2 GB' }
      withName: NORM    { cpus = 1; memory = '1 GB' }
      withName: KAIJU   { cpus = 1; memory = '2 GB' }
    }
  }

  /*
   * =========================================================
   * LOWMEM — Notebook 8GB (Safe Mode)
   * =========================================================
   */

  lowmem {

    process {

      executor      = 'local'
      shell         = ['/bin/bash', '-euo', 'pipefail']
      errorStrategy = 'terminate'
      conda         = "$projectDir/envs/brseqtb.yml"

      // Conservador para 8GB
      maxForks = 2

      withName: KAIJU_DB               { cpus = 1; maxForks = 1 }
      withName: OMS_CATALOG            { cpus = 1; maxForks = 1 }
      withName: BWA_REF                { cpus = 1; maxForks = 1 }
      withName: GATK_DICT              { cpus = 1; maxForks = 1 }
      withName: SNPEFF_DB              { cpus = 1; maxForks = 1 }
      withName: MAKE_MANIFEST_VALIDATE { cpus = 1; maxForks = 1 }

      // Heavy tools reduzidos
      withName: BWA         { cpus = 2; memory = '2 GB'; maxForks = 1 }
      withName: GATK_GVCF   { cpus = 2; memory = '4 GB'; maxForks = 1 }
      withName: GATK_VCF    { cpus = 2; memory = '4 GB'; maxForks = 1 }
      withName: IQTREE      { cpus = 2; memory = '2 GB'; maxForks = 1 }
      
      withName: COHORT       { cpus = 1; maxForks = 1; memory = '2 GB' }
      withName: SNP_MATRIX   { cpus = 2; maxForks = 1; memory = '4 GB' }
      withName: TRANSMISSION { cpus = 2; maxForks = 1; memory = '2 GB' }

      withName: TRIMMOMATIC { cpus = 1; memory = '1 GB'; maxForks = 1 }

      withName: FASTQC  { cpus = 1; memory = '512 MB' }
      withName: DELLY   { cpus = 1; memory = '1 GB' }
      withName: LOFREQ  { cpus = 1; memory = '1 GB' }
      withName: SNPEFF  { cpus = 1; memory = '1 GB' }
      withName: NORM    { cpus = 1; memory = '512 MB' }
      withName: KAIJU   { cpus = 1; memory = '1 GB' }
    }
  }

  /*
   * =========================================================
   * HPC — Scheduler Driven
   * =========================================================
   */

  hpc {

    process {

      executor = 'slurm'
      shell         = ['/bin/bash', '-euo', 'pipefail']
      errorStrategy = 'terminate'
      conda         = "$projectDir/envs/brseqtb.yml"

      withName: KAIJU_DB               { cpus = 1 }
      withName: OMS_CATALOG            { cpus = 1 }
      withName: BWA_REF                { cpus = 1 }
      withName: GATK_DICT              { cpus = 1 }
      withName: SNPEFF_DB              { cpus = 1 }
      withName: MAKE_MANIFEST_VALIDATE { cpus = 1 }

      withName: BWA         { cpus = 8; memory = '8 GB' }
      withName: GATK_GVCF   { cpus = 8; memory = '16 GB' }
      withName: GATK_VCF    { cpus = 8; memory = '16 GB' }
      withName: IQTREE      { cpus = 8; memory = '8 GB' }
      
      withName: COHORT       { cpus = 1; memory = '2 GB' }
      withName: SNP_MATRIX   { cpus = 2; memory = '4 GB' }
      withName: TRANSMISSION { cpus = 2; memory = '2 GB' }

      withName: TRIMMOMATIC { cpus = 4; memory = '4 GB' }

      withName: FASTQC  { cpus = 2 }
      withName: DELLY   { cpus = 1 }
      withName: LOFREQ  { cpus = 2 }
      withName: SNPEFF  { cpus = 2 }
      withName: NORM    { cpus = 1 }
      withName: KAIJU   { cpus = 2 }
    }
  }
}

/*
 * ============================================================
 * WORK DIRECTORY
 * ============================================================
 */

workDir = 'work'

trace    { enabled = true; file = 'logs/trace.txt';    overwrite = true }
timeline { enabled = true; file = 'logs/timeline.html'; overwrite = true }
report   { enabled = true; file = 'logs/report.html';   overwrite = true }
dag      { enabled = true; file = 'logs/dag.html';      overwrite = true }
